      #|  n = (hx >> 31) + 1
      #|  if (n | yisint) == 0 {
      #|    return not_a_number
      #|  }
      #|  s = ONE // s (sign of result -ve**odd) = -1 else = 1
      #|  if (n | (yisint - 1)) == 0 {
