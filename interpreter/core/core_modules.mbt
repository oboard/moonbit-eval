      #|  } else {
      #|    z1 ^ 0xaaaaaaaaaaaaaaaa
      #|  }
      #|}
      #|pub impl Default for RandomState with default() {
      #|  new()
      #|}
      #|test "non-zero default" {
      #|  let rs = RandomState::default()
      #|  assert_not_eq(rs.seed, 0)
      #|  assert_not_eq(rs.gamma, 0)
