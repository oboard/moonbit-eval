      #|  inspect(dst, content="[2, 3, 4, 0, 0]")
      #|}
      #|test "ArrayView::blit_to/with_offset" {
      #|  let src = [1, 2, 3, 4, 5]
      #|  let view = src[1:4] // view = [2, 3, 4]
      #|  let dst = [0, 0, 0, 0, 0]
