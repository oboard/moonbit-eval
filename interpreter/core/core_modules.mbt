      #|  for i in 0..<1000 {
      #|    expected[i] = i
      #|  }
      #|  assert_eq(arr, expected)
      #|}
      #|test "fixed_heap_sort" {
      #|  fixed_test_sort(arr => fixed_heap_sort(arr.mut_view()))
