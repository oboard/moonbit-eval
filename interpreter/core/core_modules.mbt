      #|  i = 6
      #|  ([1, 2, 3, 4, 5] : FixedArray[_]).rev_each(f)
      #|  assert_false(failed)
      #|  inspect(i, content="1")
      #|}
      #|pub fn[T] FixedArray::rev_eachi(
      #|  self : FixedArray[T],
      #|  f : (Int, T) -> Unit raise?,
