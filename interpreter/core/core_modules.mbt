    "bool.mbt": (
      #|pub fn Bool::to_int(self : Bool) -> Int {
      #|  if self {
      #|    1
      #|  } else {
      #|    0
      #|  }
      #|}
      #|pub fn Bool::to_int64(self : Bool) -> Int64 {
      #|  if self {
      #|    1
      #|  } else {
      #|    0
      #|  }
      #|}
      #|pub fn Bool::to_uint(self : Bool) -> UInt {
      #|  if self {
      #|    1
      #|  } else {
      #|    0
      #|  }
      #|}
