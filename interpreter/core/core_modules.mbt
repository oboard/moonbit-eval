      #|    let limit = if !balanced { limit - 1 } else { limit }
      #|    if pred is Some(p) {
      #|      if p == arr[pivot] {
      #|        let i = for i = pivot; i < len && p == arr[i]; {
      #|          continue i + 1
      #|        } nobreak {
      #|          i
      #|        }
      #|        continue limit, arr.slice(i, len), pred, was_partitioned, balanced
      #|      }
