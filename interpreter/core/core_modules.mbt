      #|pub fn RandomState::next_double(self : RandomState) -> Double {
      #|  let u = self.next_uint64()
      #|  (u >> 11).to_double() * double_ulp
      #|}
      #|pub fn RandomState::split(self : RandomState) -> RandomState {
      #|  let seed1 = self.seed + self.gamma
