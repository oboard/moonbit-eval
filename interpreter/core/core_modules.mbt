      #|    }
      #|    i = i + 1
      #|  }
      #|  {
      #|    i = 0
      #|    ([] : FixedArray[_]).eachi(f)
      #|    assert_false(failed)
      #|    inspect(i, content="0")
      #|  }
      #|  {
      #|    i = 0
      #|    ([1] : FixedArray[_]).eachi(f)
      #|    assert_false(failed)
      #|    inspect(i, content="1")
      #|  }
      #|  i = 0
      #|  ([1, 2, 3, 4, 5] : FixedArray[_]).eachi(f)
      #|  assert_false(failed)
      #|  inspect(i, content="5")
      #|}
