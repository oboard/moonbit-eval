      #|const POW_P2 = -2.77777777770155933842e-03
      #|const POW_P3 = 6.61375632143793436117e-05
      #|const POW_P4 = -1.65339022054652515390e-06
      #|const POW_P5 = 4.13813679705723846039e-08
