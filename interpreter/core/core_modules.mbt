      #|    assert_eq(arr, [])
      #|  }
      #|  {
      #|    let arr : FixedArray[_] = [6]
      #|    arr.fill(5)
      #|    assert_eq(arr, [5])
      #|  }
      #|  let arr : FixedArray[_] = [0, 0, 0, 0, 0]
      #|  arr.fill(3)
      #|  assert_eq(arr, [3, 3, 3, 3, 3])
      #|}
