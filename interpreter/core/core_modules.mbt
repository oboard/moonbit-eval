      #|struct MatchResult {
      #|  input : StringView
      #|  group_names : ReadOnlyArray[String?]
      #|  result : @re.MatchResult
      #|} derive(Debug)
      #|pub fn MatchResult::before(self : MatchResult) -> StringView {
      #|  guard self.result.group(0) is Some((start, _end)) else { panic() }
      #|  self.input[0:start]
