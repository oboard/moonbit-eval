      #|      z = ax // x is +-0,+-inf,+-1 */
      #|      if hy < 0 {
      #|        z = ONE / z // z = (1/|x|)
      #|      }
      #|      if hx < 0 {
      #|        if ((ix - 0x3ff00000) | yisint) == 0 {
