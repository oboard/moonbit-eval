      #|    self.counter = 0
      #|  }
      #|  chacha_block(self.seed, self.buffer, self.counter)
      #|  self.i = 0
      #|  self.n = if self.counter == COUNTER_MAX - COUNTER_INC {
      #|    (BUFFER_CHUNK_NUM - SEED_CHUNK_NUM).reinterpret_as_uint()
      #|  } else {
      #|    BUFFER_CHUNK_NUM.reinterpret_as_uint()
      #|  }
      #|}
