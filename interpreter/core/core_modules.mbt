      #|  let arr = FixedArray::make(1000, 0)
      #|  for i in 0..<1000 {
      #|    arr[i] = 1000 - i - 1
      #|  }
      #|  for step in 1..<100 {
      #|    let i = step * 10
      #|    arr.swap(i, i - 1)
      #|  }
      #|  arr.mut_view().stable_sort()
      #|  let expected = FixedArray::make(1000, 0)
      #|  for i in 0..<1000 {
      #|    expected[i] = i
