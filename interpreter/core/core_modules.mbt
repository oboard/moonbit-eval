      #|    }
      #|  } else {
      #|    nn(l, lo, hi, r)
      #|  }
      #|}
      #|fn cat(l : Tree, r : Tree) -> Tree {
      #|  match (l, r) {
      #|    (Tree::Empty, r) => r
      #|    (l, Tree::Empty) => l
      #|    (Tree::Node(..) as l, Tree::Node(..) as r) => {
      #|      fn go(r : Tree) -> Tree {
      #|        match r {
      #|          Empty => panic()
      #|          Node(l=Empty, lo~, hi~, r~, ..) => nn(l, lo, hi, r)
      #|          Node(l=Node(_) as l, lo~, hi~, r~, ..) => bal(go(l), lo, hi, r)
      #|        }
      #|      }
      #|      go(r)
      #|    }
      #|  }
      #|}
