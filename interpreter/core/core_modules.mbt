      #|    uint64_x = uint64_x | (ex.to_uint64() << 52)
      #|  } else {
      #|    uint64_x = uint64_x >> (-ex + 1)
      #|  }
      #|  uint64_x = uint64_x | (sign_x << 63)
      #|  uint64_x.reinterpret_as_double()
      #|}
    ),
