    "option.mbt": (
      #|pub impl[X : Eq] Eq for X? with equal(self, other) {
      #|  match (self, other) {
      #|    (None, None) => true
      #|    (Some(x), Some(y)) => x == y
      #|    _ => false
      #|  }
      #|}
      #|pub fn[X : Show] Option::to_string(self : X?) -> String {
      #|  match self {
      #|    None => "None"
      #|    Some(x) => "Some(" + x.to_string() + ")"
      #|  }
      #|}
      #|pub fn[X] Option::unwrap(self : X?) -> X {
      #|  match self {
      #|    None => panic()
      #|    Some(x) => x
      #|  }
      #|}
      #|#alias(or, deprecated)
