      #|  let mut z_l : Double = 0.0
      #|  let mut p_h : Double = 0.0
      #|  let mut p_l : Double = 0.0
      #|  let mut y1 : Double = 0.0
      #|  let mut t1 : Double = 0.0
      #|  let mut t2 : Double = 0.0
