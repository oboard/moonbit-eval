      #|) -> Unit {
      #|  guard len >= 0 &&
      #|    dst_offset >= 0 &&
      #|    src_offset >= 0 &&
      #|    dst_offset <= dst.length() &&
      #|    src_offset + len <= self.length()
      #|  if dst_offset + len > dst.length() {
      #|    dst.unsafe_grow_to_length(dst_offset + len)
      #|  }
      #|  Array::unsafe_blit(dst, dst_offset, self, src_offset, len)
      #|}
      #|pub fn[A] ArrayView::blit_to(
      #|  self : ArrayView[A],
      #|  dst : Array[A],
      #|  dst_offset? : Int = 0,
      #|) -> Unit {
      #|  let len = self.len()
