      #|fn mix64variant13(z0 : UInt64) -> UInt64 {
      #|  let z1 = shift_xor_mul(30, 0xbf58476d1ce4e5b9, z0)
      #|  let z2 = shift_xor_mul(27, 0x94d049bb133111eb, z1)
