      #|  inspect(dst, content="[0, 0, 2, 3, 4]")
      #|}
      #|test "ArrayView::blit_to/grow_destination" {
      #|  let src = [1, 2, 3, 4, 5]
      #|  let view = src[1:4] // view = [2, 3, 4]
