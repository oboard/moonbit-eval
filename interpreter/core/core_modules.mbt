///|
let moonbitlang_core_int16_module : RuntimePackage = RuntimePackage::new(
  "moonbitlang/core/int16",
  deps={},
  files={
    "int16.mbt": (
      #|pub const MAX_VALUE : Int16 = 32767
      #|#deprecated("Use `MAX_VALUE` instead")
