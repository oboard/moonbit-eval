      #|          return
      #|        }
      #|        continue psl + 1, (idx + 1) & self.capacity_mask
      #|      }
      #|    }
      #|  }
      #|}
      #|fn[K, V] Map::push_away(
      #|  self : Map[K, V],
      #|  idx : Int,
      #|  entry : Entry[K, V],
      #|) -> Unit {
      #|  for psl = entry.psl + 1, idx = (idx + 1) & self.capacity_mask, entry = entry {
