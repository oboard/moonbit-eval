      #|  let mut capacity = length.next_power_of_two()
      #|  if length > calc_grow_threshold(capacity) {
      #|    capacity *= 2
      #|  }
      #|  let m = Map::new(capacity~)
      #|  for e in arr {
      #|    m.set(e.0, e.1)
