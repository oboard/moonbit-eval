      #|pub fn[K, V] Map::new(capacity? : Int = 8) -> Map[K, V] {
      #|  let capacity = capacity.next_power_of_two()
      #|  {
      #|    size: 0,
      #|    capacity,
      #|    capacity_mask: capacity - 1,
      #|    grow_at: calc_grow_threshold(capacity),
      #|    entries: FixedArray::make(capacity, None),
      #|    head: None,
      #|    tail: -1,
      #|  }
      #|}
