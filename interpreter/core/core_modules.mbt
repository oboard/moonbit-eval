      #|pub fn RandomState::next_int(self : RandomState) -> Int {
      #|  self.next_uint().reinterpret_as_int()
      #|}
      #|pub fn RandomState::next_positive_int(self : RandomState) -> Int {
      #|  let r = self.next_int()
