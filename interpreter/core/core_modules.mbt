      #|    assert_false(arr.any(ele => ele < 5))
      #|  }
      #|  {
      #|    let arr : FixedArray[_] = [5]
      #|    assert_true(arr.any(ele => ele < 6))
      #|    assert_false(arr.any(ele => ele < 5))
      #|  }
      #|  let arr : FixedArray[_] = [1, 2, 3, 4, 5]
      #|  assert_true(arr.any(ele => ele < 6))
      #|  assert_true(arr.any(ele => ele < 5))
      #|}
      #|test "fill" {
      #|  {
      #|    let arr : FixedArray[Int] = []
