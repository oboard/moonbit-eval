      #|fn[T : Compare] fixed_heap_sort(arr : MutArrayView[T]) -> Unit {
      #|  let len = arr.length()
      #|  for i in (len / 2)>..0 {
      #|    fixed_sift_down(arr, i)
      #|  }
      #|  for i in len>..1 {
      #|    arr.swap(0, i)
      #|    fixed_sift_down(arr.slice(0, i), 0)
