      #|pub fn Int16::to_int(self : Int16) -> Int = "%i16_to_i32"
      #|pub fn Int16::to_byte(self : Int16) -> Byte = "%i16_to_byte"
      #|pub fn Int16::to_string(self : Int16, radix? : Int = 10) -> String {
      #|  self.to_int().to_string(radix~)
      #|}
    ),
  },
)

