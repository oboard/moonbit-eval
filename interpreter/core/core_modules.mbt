      #|  }
      #|}
      #|fn fixed_test_sort(f : (MutArrayView[Int]) -> Unit) -> Unit raise {
      #|  let arr : FixedArray[_] = [5, 4, 3, 2, 1]
      #|  f(arr.mut_view())
      #|  assert_eq(arr, [1, 2, 3, 4, 5])
      #|  let arr : FixedArray[_] = [5, 5, 5, 5, 1]
      #|  f(arr.mut_view())
      #|  assert_eq(arr, [1, 5, 5, 5, 5])
