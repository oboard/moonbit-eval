      #|pub fn[X] FixedArray::iter(self : FixedArray[X]) -> Iter[X] {
      #|  self[:].iter()
      #|}
      #|#alias(iterator2, deprecated)
      #|pub fn[X] FixedArray::iter2(self : FixedArray[X]) -> Iter2[Int, X] {
      #|  self[:].iter2()
