      #|    arr[i] = arr[j]
      #|    arr[j] = temp
      #|  }
      #|}
      #|fn[T : Compare] fixed_quick_sort(
      #|  arr : MutArrayView[T],
      #|  pred : T?,
      #|  limit : Int,
