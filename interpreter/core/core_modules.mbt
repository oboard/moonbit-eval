      #|  if self {
      #|    1
      #|  } else {
      #|    0
      #|  }
      #|}
      #|pub impl Hash for Bool with hash_combine(self, hasher) {
      #|  hasher.combine_bool(self)
      #|}
      #|pub fn Bool::to_uint16(self : Bool) -> UInt16 {
      #|  if self {
      #|    1
      #|  } else {
      #|    0
      #|  }
      #|}
